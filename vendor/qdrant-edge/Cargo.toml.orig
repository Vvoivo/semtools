[package]
name = "qdrant-edge"
version = "0.0.0"
authors = ["Qdrant Team <info@qdrant.tech>"]
license = "Apache-2.0"
edition = "2024"
description = "A lightweight, in-process vector search engine designed for embedded devices, autonomous systems, and mobile agents."
publish = true

[dependencies]
ahash = {version = "0.8.11", features = ["serde"]}
tonic = {version = "0.11.0", features = ["gzip", "tls"]}
prost = {version = "0.12.6"}
prost-wkt-types = {version = "0.5"}
serde = {version = "~1.0", features = ["derive", "rc"]}
serde_json = {version = "~1.0", features = ["preserve_order"]}
schemars = {version = "0.8.22", features = [
    "uuid1",
    "preserve_order",
    "chrono",
    "url",
    "indexmap2",
]}
uuid = {version = "1.21", features = ["v4", "serde"]}
tokio = {version = "1.49.0", features = ["full"]}
rand = {version = "0.10.0"}
chrono = {version = "0.4.43", features = ["serde"]}
thiserror = {version = "2.0.18"}
parking_lot = {version = "0.12.5", features = ["arc_lock", "deadlock_detection", "serde"]}
validator = {version = "0.20.0", features = ["derive"]}
itertools = {version = "0.14.0"}
ordered-float = {version = "5.1.0", features = ["serde", "schemars"]}
atomicwrites = {version = "0.4.4"}
bincode = {version = "1.3.3"}
bitvec = {version = "1.0.1"}
bytemuck = {version = "1.25.0", features = [
    "derive",
    "extern_crate_alloc",
    "must_cast",
    "transparentwrapper_extra",
]}
delegate = {version = "0.13.5"}
fs-err = {version = "3.2.2", features = ["tokio"]}
fs_extra = {version = "1.3.0"}
log = {version = "0.4.29"}
memmap2 = {version = "0.9.10"}
nix = {version = "0.31", features = ["fs", "feature"]}
num-traits = {version = "0.2.19"}
num_cpus = {version = "1.17"}
ph = {version = "0.8.5"}
semver = {version = "1.0", features = ["serde"]}
strum = {version = "0.28.0", features = ["derive"]}
tap = {version = "1.0.1"}
tar = {version = "0.4.41"}
tempfile = {version = "3.25.0"}
walkdir = {version = "2.5.0"}
zerocopy = {version = "0.8.40", features = ["derive"]}
ecow = {version = "0.2.6", features = ["serde"]}
serde_cbor = {version = "0.11.2"}
smallvec = {version = "1.15.1", features = ["write"]}
lz4_flex = {version = "0.12.0", default-features = false}
bitpacking = {version = "0.9.3"}
permutation_iterator = {version = "0.1.2"}
rayon = {version = "1.11.0"}
arrayvec = {version = "0.7.6"}
data-encoding = {version = "2.10.0"}
integer-encoding = {version = "4.1.0"}
serde-value = {version = "0.7"}
serde_variant = {version = "0.1.3"}
serde-untagged = {version = "0.1.9"}
atomic_refcell = {version = "0.1.13"}
geo = {version = "0.32.0"}
geohash = {version = "0.13.1"}
num-derive = {version = "0.4.2"}
num-cmp = {version = "0.1.0"}
seahash = {version = "4.1.0"}
tinyvec = {version = "1.10.0", features = ["alloc", "latest_stable_rust"]}
fnv = {version = "1.0"}
indexmap = {version = "2", features = ["serde"]}
self_cell = {version = "1.2.2"}
sha2 = {version = "0.10.9"}
is_sorted = {version = "0.1.1"}
byteorder = {version = "1.5.0"}
vaporetto = {version = "0.6.5"}
rust-stemmers = {package = "qdrant-rust-stemmers", version = "1.2.2"}
sysinfo = {version = "0.38"}
charabia = {version = "0.9.7", default-features = false, features = [
    "greek",
    "hebrew",
    "thai",
    "chinese-segmentation",
    "chinese-normalization",
]}
macro_rules_attribute = {version = "0.2.2"}
nom = {version = "8.0.0"}
half = {version = "2.7.1", features = [
    "alloc",
    "bytemuck",
    "serde",
    "num-traits",
]}
roaring = {version = "0.11.3"}
rmp-serde = {version = "~1.3"}
fs4 = {version = "0.13.1"}
crc32c = {version = "0.6.8"}
rand_distr = {version = "0.6.0"}
rustix = {version = "1", features = ["fs"]}
docopt = {version = "1.1"}
env_logger = {version = "0.11"}

[dev-dependencies]
tokio = {version = "1.49.0", features = ["full"]}
criterion = {version = "0.8.2"}
fs-err = {version = "3.2.2", features = ["debug"]}
itertools = {version = "0.14.0"}
rstest = {version = "0.26.1", default-features = false}
self_cell = {version = "1.2.2"}
serde_json = {version = "~1.0", features = ["preserve_order"]}
tango-bench = {version = "0.6.0"}
anyhow = {version = "1.0.102"}
csv = {version = "1.4.0"}
proptest = {version = "1.10.0", default-features = false, features = ["std"]}
bustle = {version = "0.5.1"}
env_logger = {version = "0.11"}
rand = {version = "0.10.0"}
num_threads = {version = "0.1.6"}
rand_distr = {version = "0.6.0"}
tempfile = {version = "3.25.0"}
clap = {version = "4.5.58", features = ["derive", "env"]}
humantime = {version = "2.3.0"}
indicatif = {version = "0.18.4", features = ["rayon"]}
ndarray = {version = "0.17.2"}
ndarray-npy = {version = "0.10.0", default-features = false}
rmp-serde = {version = "~1.3"}
walkdir = {version = "2.5.0"}
serde_cbor = {version = "0.11.2"}
tar = {version = "0.4.41"}
generic-tests = {version = "0.1.3"}
chrono = {version = "0.4.43", features = ["serde"]}
crc = {version = "3.3.0"}
hdrhistogram = {version = "7.5.4"}
quickcheck = {version = "1.0.3"}
regex = {version = "1.11.3"}

[target."cfg(target_os = \"linux\")".dependencies]
thread-priority = {version = "3.0.0"}
cgroups-rs = {version = "0.3"}
procfs = {version = "0.18", default-features = false}
io-uring = {version = "0.7.11"}

[target."cfg(not(target_os = \"windows\"))".dev-dependencies]
pprof = {version = "0.15.0", features = ["flamegraph", "prost-codec"]}

[build-dependencies]
cc = {version = "1.2"}
